{
  "pools": {
    "example-oauth-provider": {
      "type": "oauth",
      "keys": [
        {
          "label": "my-account",
          "access": "<OAUTH_ACCESS_TOKEN>",
          "refresh": "<OAUTH_REFRESH_TOKEN>",
          "expires": 0,
          "accountId": "<ACCOUNT_ID>"
        }
      ],
      "cooldownMs": 300000,
      "fallbackModel": "provider/model-name"
    },
    "example-env-provider": {
      "keys": [
        { "env": "MY_API_KEY_1", "label": "primary" },
        { "env": "MY_API_KEY_2", "label": "fallback" }
      ],
      "cooldownMs": 60000,
      "fallbackModel": "provider/model-name"
    },
    "example-apikey-provider": {
      "type": "api_key",
      "keys": [
        { "value": "<RAW_API_KEY>", "label": "primary" }
      ],
      "cooldownMs": 60000,
      "fallbackModel": "provider/model-name"
    }
  }
}
